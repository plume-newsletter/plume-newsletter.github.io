            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span id="copy-label">{t.quickstart.copyLabel}</span>
          </button>
        </div>
        <pre style="margin:0;padding:20px;overflow-x:auto;font-family:'JetBrains Mono Variable',monospace;font-size:.84rem;line-height:1.9;color:var(--code-fg);"><span style="color:#7d8590;">{t.quickstart.terminalComment1}</span>
<span style="color:#7ee787;">git</span> clone https://github.com/plume-newsletter/plume.git
<span style="color:#7ee787;">cd</span> plume <span style="color:#ff7b72;">&amp;&amp;</span> cp .env.example .env

<span style="color:#7d8590;">{t.quickstart.terminalComment2}</span>
