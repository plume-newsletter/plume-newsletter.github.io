            <li style="display:flex;gap:10px;align-items:flex-start;font-size:.92rem;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px;"><polyline points="20 6 9 17 4 12"/></svg>{t.cloud.plumeCloud.features[1]}</li>
            <li style="display:flex;gap:10px;align-items:flex-start;font-size:.92rem;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--amber)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px;"><polyline points="20 6 9 17 4 12"/></svg>{t.cloud.plumeCloud.features[2]}</li>
