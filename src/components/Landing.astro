              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><path d="M17.5 15H9"/></svg>
            </span>
            <span style="font-weight:700;font-size:1.1rem;">{t.footer.brand}</span>
          </div>
          <p style="color:var(--muted);font-size:.9rem;margin:14px 0 0;">{t.footer.tagline}</p>
        </div>
        <div>
          <h4 style="font-size:.78rem;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);margin:0 0 12px;">{t.footer.productHeading}</h4>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:9px;">
            <li><a href="#features" style="text-decoration:none;color:var(--fg);font-size:.92rem;" style-hover="color:var(--primary);">{t.footer.productLinks.features}</a></li>
            <li><a href="#pricing" style="text-decoration:none;color:var(--fg);font-size:.92rem;" style-hover="color:var(--primary);">{t.footer.productLinks.pricing}</a></li>
            <li><a href={locale === 'th' ? '/th/compare/' : '/compare/'} style="text-decoration:none;color:var(--fg);font-size:.92rem;" style-hover="color:var(--primary);">{t.footer.productLinks.compare}</a></li>
            <li><a href="#plans" style="text-decoration:none;color:var(--fg);font-size:.92rem;" style-hover="color:var(--primary);">{t.footer.productLinks.cloud}</a></li>
            <li><a href="#how" style="text-decoration:none;color:var(--fg);font-size:.92rem;" style-hover="color:var(--primary);">{t.footer.productLinks.how}</a></li>
