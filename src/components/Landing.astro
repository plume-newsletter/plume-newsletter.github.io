          <div style="display:flex;align-items:baseline;gap:8px;margin:20px 0 4px;"><span style="font-size:2.6rem;font-weight:800;letter-spacing:-.02em;">{t.cloud.selfHosted.priceValue}</span><span style="color:var(--muted);font-size:.95rem;">{t.cloud.selfHosted.priceUnit}</span></div>
          <p style="color:var(--muted);font-size:.9rem;margin:0 0 20px;">{t.cloud.selfHosted.body}</p>
          <a href="#quickstart" style="display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;color:#fff;font-weight:600;padding:12px;border-radius:10px;background:var(--primary);box-shadow:var(--shadow-sm);margin-bottom:22px;" style-hover="background:var(--primary-hover);" style-focus="outline:2px solid var(--primary);outline-offset:2px;">{t.cloud.selfHosted.cta}</a>
