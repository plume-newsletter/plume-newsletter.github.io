---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import type { LandingStrings } from '../i18n/landing';
const { locale, t } = Astro.props as { locale: 'en' | 'th'; t: LandingStrings };
const site = Astro.site?.href ?? '/';
const docsBase = locale === 'th' ? '/th/docs' : '/docs';
const canonical = locale === 'th' ? new URL('th/', site).href : site;
const hreflangEn = site;
const hreflangTh = new URL('th/', site).href;
---
<!doctype html>
<html lang={locale}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{t.meta.title}</title>
  <meta name="description" content={t.meta.description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en" href={hreflangEn} />
  <link rel="alternate" hreflang="th" href={hreflangTh} />
  <link rel="alternate" hreflang="x-default" href={hreflangEn} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={t.meta.title} />
  <meta property="og:description" content={t.meta.ogDescription} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={t.meta.title} />
  <meta name="twitter:description" content={t.meta.ogDescription} />
  <meta property="og:image" content="https://plumenewsletter.com/og.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:image" content="https://plumenewsletter.com/og.png" />
  <style is:global>
*{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{margin:0;}
  ::selection{background:oklch(0.623 0.188 260 / 0.18);}
  :root{
    --bg:oklch(0.984 0.003 247.858);
    --surface:#ffffff;
    --surface-2:oklch(0.972 0.006 256.695);
    --fg:oklch(0.208 0.040 265.755);
    --muted:oklch(0.554 0.041 257.417);
    --border:oklch(0.913 0.017 256.284);
    --border-strong:oklch(0.872 0.020 256);
    --primary:oklch(0.623 0.188 260);
    --primary-weak:oklch(0.949 0.028 260);
    --primary-hover:oklch(0.560 0.188 260);
    --primary-text:oklch(0.470 0.188 260);
    --amber:oklch(0.555 0.146 48.998);
    --amber-weak:oklch(0.952 0.035 70);
    --success:oklch(0.491 0.176 162.48);
    --success-weak:oklch(0.95 0.04 162);
    --shadow-sm:0 1px 2px rgba(15,23,42,.05);
    --shadow:0 1px 2px rgba(15,23,42,.06),0 12px 28px -14px rgba(15,23,42,.18);
    --shadow-lg:0 1px 2px rgba(15,23,42,.06),0 30px 60px -28px rgba(15,23,42,.28);
    --code-bg:oklch(0.205 0.030 264.665);
    --code-fg:oklch(0.929 0.013 255.508);
    --nav-bg:rgba(248,250,252,.78);
  }
  [data-theme="dark"]{
    --bg:oklch(0.183 0.031 263.383);
    --surface:oklch(0.210 0.032 264.665);
    --surface-2:oklch(0.245 0.034 262);
    --fg:oklch(0.929 0.013 255.508);
    --muted:oklch(0.711 0.035 256.788);
    --border:oklch(0.278 0.030 256.848);
    --border-strong:oklch(0.345 0.032 258);
    --primary:oklch(0.623 0.188 259.815);
    --primary-weak:oklch(0.300 0.062 262);
    --primary-hover:oklch(0.680 0.188 259.815);
    --primary-text:oklch(0.720 0.150 262);
    --amber:oklch(0.705 0.142 55);
    --amber-weak:oklch(0.300 0.060 60);
    --success:oklch(0.627 0.194 145.57);
    --success-weak:oklch(0.300 0.070 150);
    --shadow-sm:0 1px 2px rgba(0,0,0,.4);
    --shadow:0 1px 2px rgba(0,0,0,.4),0 14px 32px -16px rgba(0,0,0,.6);
    --shadow-lg:0 1px 2px rgba(0,0,0,.45),0 36px 70px -30px rgba(0,0,0,.75);
    --code-bg:oklch(0.160 0.024 263);
    --code-fg:oklch(0.929 0.013 255.508);
    --nav-bg:rgba(20,27,45,.72);
  }

  /* --faint is referenced by the prototype but never defined there */
  :root{--faint:oklch(0.65 0.03 257);}
  [data-theme="dark"]{--faint:oklch(0.58 0.035 257);}
  html,body{background:var(--bg);}
  /* theme toggle: show the icon for the action you'd take next */
  html[data-theme="dark"] .theme-ico-light{display:none;}
  html:not([data-theme="dark"]) .theme-ico-dark{display:none;}
  .theme-ico{display:inline-flex;}
  </style>
  <script is:inline>
    // set theme before paint to avoid a flash of the wrong palette
    (function () {
      var t = localStorage.getItem('theme');
      if (t !== 'light' && t !== 'dark') {
        t = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
<div style="background:var(--bg);color:var(--fg);font-family:'Inter','Inter Variable',system-ui,-apple-system,sans-serif;min-height:100vh;line-height:1.5;-webkit-font-smoothing:antialiased;transition:background .35s ease,color .35s ease;overflow-x:hidden;">

  <a href="#main" style="position:absolute;left:-999px;top:8px;z-index:200;background:var(--primary);color:#fff;padding:8px 14px;border-radius:8px;text-decoration:none;" style-focus="left:12px;">{t.nav.skip}</a>

  <!-- ===================== NAV ===================== -->
  <header style="position:sticky;top:0;z-index:100;backdrop-filter:saturate(140%) blur(12px);-webkit-backdrop-filter:saturate(140%) blur(12px);background:var(--nav-bg);border-bottom:1px solid var(--border);">
    <nav aria-label={t.nav.primaryAria} style="max-width:1180px;margin:0 auto;padding:13px 24px;display:flex;align-items:center;gap:18px;flex-wrap:wrap;">
      <a href="#main" aria-label={t.nav.homeAria} style="display:flex;align-items:center;gap:10px;text-decoration:none;color:var(--fg);margin-right:auto;">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:9px;background:var(--primary);box-shadow:var(--shadow-sm);">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><path d="M17.5 15H9"/></svg>
        </span>
        <span style="font-weight:700;font-size:1.15rem;letter-spacing:-.01em;">{t.nav.brand}</span>
        <span style="font-family:'JetBrains Mono Variable',monospace;font-size:.62rem;font-weight:600;color:var(--muted);border:1px solid var(--border);border-radius:5px;padding:2px 6px;letter-spacing:.02em;">{t.nav.badge}</span>
      </a>
      <div style="display:flex;align-items:center;gap:4px;flex-wrap:wrap;">
        <a href="#why" style="text-decoration:none;color:var(--muted);font-size:.92rem;font-weight:500;padding:8px 12px;border-radius:8px;" style-hover="color:var(--fg);background:var(--surface-2);">{t.nav.why}</a>
        <a href="#features" style="text-decoration:none;color:var(--muted);font-size:.92rem;font-weight:500;padding:8px 12px;border-radius:8px;" style-hover="color:var(--fg);background:var(--surface-2);">{t.nav.features}</a>
        <a href="#how" style="text-decoration:none;color:var(--muted);font-size:.92rem;font-weight:500;padding:8px 12px;border-radius:8px;" style-hover="color:var(--fg);background:var(--surface-2);">{t.nav.how}</a>
        <a href="#pricing" style="text-decoration:none;color:var(--muted);font-size:.92rem;font-weight:500;padding:8px 12px;border-radius:8px;" style-hover="color:var(--fg);background:var(--surface-2);">{t.nav.pricing}</a>
        <a href={`${docsBase}/`} style="text-decoration:none;color:var(--muted);font-size:.92rem;font-weight:500;padding:8px 12px;border-radius:8px;" style-hover="color:var(--fg);background:var(--surface-2);">{t.nav.docs}</a>
        <a href="#plans" style="text-decoration:none;color:var(--muted);font-size:.92rem;font-weight:500;padding:8px 12px;border-radius:8px;" style-hover="color:var(--fg);background:var(--surface-2);">{t.nav.cloud}</a>
        <a href={locale === 'th' ? '/' : '/th/'} lang={locale === 'th' ? 'en' : 'th'}
           style="text-decoration:none;color:var(--muted);font-size:.92rem;font-weight:500;padding:8px 12px;border-radius:8px;"
           style-hover="color:var(--fg);background:var(--surface-2);">{locale === 'th' ? t.nav.toggleToEn : t.nav.toggleToTh}</a>
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <button id="theme-toggle" aria-label={t.nav.themeToggleAria} style="display:inline-flex;align-items:center;justify-content:center;width:38px;height:38px;border-radius:9px;border:1px solid var(--border);background:var(--surface);color:var(--fg);cursor:pointer;" style-hover="background:var(--surface-2);border-color:var(--border-strong);" style-focus="outline:2px solid var(--primary);outline-offset:2px;">
          <div class="theme-ico theme-ico-dark">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          </div>
          <div class="theme-ico theme-ico-light">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13.5A8 8 0 1 1 10.5 4a6.2 6.2 0 0 0 9.5 9.5Z"/></svg>
          </div>
        </button>
        <a href="https://github.com/plume-newsletter/plume" style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;color:var(--fg);font-size:.92rem;font-weight:600;padding:9px 14px;border-radius:9px;border:1px solid var(--border);background:var(--surface);" style-hover="background:var(--surface-2);border-color:var(--border-strong);" style-focus="outline:2px solid var(--primary);outline-offset:2px;">
          <svg width="17" height="17" viewBox="0 0 19 19" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M9.356 1.85C5.05 1.85 1.57 5.356 1.57 9.694a7.84 7.84 0 0 0 5.324 7.44c.387.079.528-.168.528-.376 0-.182-.013-.805-.013-1.454-2.165.467-2.616-.935-2.616-.935-.349-.91-.864-1.143-.864-1.143-.71-.48.051-.48.051-.48.787.051 1.2.805 1.2.805.695 1.194 1.817.857 2.268.649.064-.507.27-.857.49-1.052-1.728-.182-3.545-.857-3.545-3.87 0-.857.31-1.558.8-2.104-.078-.195-.349-1 .077-2.078 0 0 .657-.208 2.14.805a7.5 7.5 0 0 1 1.946-.26c.657 0 1.328.092 1.946.26 1.483-1.013 2.14-.805 2.14-.805.426 1.078.155 1.883.078 2.078.502.546.799 1.247.799 2.104 0 3.013-1.818 3.675-3.558 3.87.284.247.528.714.528 1.454 0 1.052-.012 1.896-.012 2.156 0 .208.142.455.528.377a7.84 7.84 0 0 0 5.324-7.441c.013-4.338-3.48-7.844-7.773-7.844" clip-rule="evenodd"/></svg>
          <span style="font-family:'JetBrains Mono Variable',monospace;font-size:.82rem;"><span id="gh-stars">{t.nav.githubStarsFallback}</span></span>
        </a>
        <a href="#quickstart" style="display:inline-flex;align-items:center;text-decoration:none;color:#fff;font-size:.92rem;font-weight:600;padding:10px 16px;border-radius:9px;background:var(--amber);box-shadow:var(--shadow-sm);" style-hover="filter:brightness(.94);" style-focus="outline:2px solid var(--amber);outline-offset:2px;">{t.nav.getStarted}</a>
      </div>
    </nav>
  </header>

  <main id="main">

    <!-- ===================== HERO ===================== -->
    <section style="max-width:1180px;margin:0 auto;padding:clamp(48px,8vw,92px) 24px clamp(40px,6vw,64px);display:flex;gap:clamp(32px,5vw,64px);flex-wrap:wrap;align-items:center;">
      <div style="flex:1 1 420px;min-width:300px;">
        <span style="display:inline-flex;align-items:center;gap:8px;font-size:.82rem;font-weight:600;color:var(--primary);background:var(--primary-weak);border:1px solid var(--border);border-radius:999px;padding:6px 12px;">
          <span style="width:6px;height:6px;border-radius:999px;background:var(--success);display:inline-block;"></span>
          {t.hero.badge}
        </span>
        <h1 style="font-size:clamp(2.3rem,5.2vw,3.7rem);line-height:1.04;letter-spacing:-.025em;font-weight:800;margin:20px 0 0;text-wrap:balance;">
          {t.hero.headlineBefore} <span style="color:var(--primary);">{t.hero.headlineHighlight}</span> {t.hero.headlineAfter}
        </h1>
        <p style="font-size:clamp(1.05rem,2vw,1.22rem);color:var(--muted);margin:18px 0 0;max-width:34ch;text-wrap:pretty;">
          {t.hero.subhead}
        </p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:28px;">
          <a href="#quickstart" style="display:inline-flex;align-items:center;gap:9px;text-decoration:none;color:#fff;font-size:1rem;font-weight:600;padding:13px 22px;border-radius:10px;background:var(--amber);box-shadow:var(--shadow);" style-hover="filter:brightness(.94);transform:translateY(-1px);" style-focus="outline:2px solid var(--amber);outline-offset:2px;">
            {t.hero.ctaPrimary}
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="https://github.com/plume-newsletter/plume" style="display:inline-flex;align-items:center;gap:9px;text-decoration:none;color:var(--fg);font-size:1rem;font-weight:600;padding:13px 20px;border-radius:10px;border:1px solid var(--border-strong);background:var(--surface);" style-hover="background:var(--surface-2);" style-focus="outline:2px solid var(--primary);outline-offset:2px;">
            <svg width="18" height="18" viewBox="0 0 19 19" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M9.356 1.85C5.05 1.85 1.57 5.356 1.57 9.694a7.84 7.84 0 0 0 5.324 7.44c.387.079.528-.168.528-.376 0-.182-.013-.805-.013-1.454-2.165.467-2.616-.935-2.616-.935-.349-.91-.864-1.143-.864-1.143-.71-.48.051-.48.051-.48.787.051 1.2.805 1.2.805.695 1.194 1.817.857 2.268.649.064-.507.27-.857.49-1.052-1.728-.182-3.545-.857-3.545-3.87 0-.857.31-1.558.8-2.104-.078-.195-.349-1 .077-2.078 0 0 .657-.208 2.14.805a7.5 7.5 0 0 1 1.946-.26c.657 0 1.328.092 1.946.26 1.483-1.013 2.14-.805 2.14-.805.426 1.078.155 1.883.078 2.078.502.546.799 1.247.799 2.104 0 3.013-1.818 3.675-3.558 3.87.284.247.528.714.528 1.454 0 1.052-.012 1.896-.012 2.156 0 .208.142.455.528.377a7.84 7.84 0 0 0 5.324-7.441c.013-4.338-3.48-7.844-7.773-7.844" clip-rule="evenodd"/></svg>
            {t.hero.ctaSecondary}
          </a>
        </div>
        <div style="display:inline-flex;align-items:center;gap:12px;margin-top:24px;font-family:'JetBrains Mono Variable',monospace;font-size:.9rem;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:10px 14px;box-shadow:var(--shadow-sm);flex-wrap:wrap;">
          <span style="color:var(--success);font-weight:600;">{t.hero.priceValue}</span>
          <span style="color:var(--muted);">{t.hero.priceUnit}</span>
          <span style="width:1px;height:16px;background:var(--border);"></span>
          <span style="color:var(--muted);font-family:'Inter',sans-serif;font-size:.84rem;">{t.hero.priceNote}</span>
        </div>
      </div>

      <!-- Hero product mock: campaign report card -->
      <div style="flex:1 1 380px;min-width:300px;">
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;box-shadow:var(--shadow-lg);overflow:hidden;">
          <div style="display:flex;align-items:center;gap:8px;padding:13px 16px;border-bottom:1px solid var(--border);">
            <span style="width:11px;height:11px;border-radius:999px;background:#ef5f56;"></span>
            <span style="width:11px;height:11px;border-radius:999px;background:#f6bd3b;"></span>
            <span style="width:11px;height:11px;border-radius:999px;background:#5fc454;"></span>
            <span style="margin-left:8px;font-family:'JetBrains Mono Variable',monospace;font-size:.78rem;color:var(--muted);">{t.hero.mockWindowLabel}</span>
          </div>
          <div style="padding:20px;">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:18px;">
              <div>
                <div style="font-weight:700;font-size:1.02rem;">{t.hero.mockCampaignTitle}</div>
                <div style="font-size:.82rem;color:var(--muted);font-family:'JetBrains Mono Variable',monospace;margin-top:2px;">{t.hero.mockCampaignMeta}</div>
              </div>
              <span style="font-size:.74rem;font-weight:600;color:var(--success);background:var(--success-weak);border-radius:999px;padding:4px 10px;white-space:nowrap;">{t.hero.mockStatus}</span>
            </div>
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;">
              <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:11px;padding:13px;">
                <div style="font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;">{t.hero.statDeliveredLabel}</div>
                <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:600;font-size:1.5rem;margin-top:4px;">{t.hero.statDeliveredValue}</div>
              </div>
              <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:11px;padding:13px;">
                <div style="font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;">{t.hero.statOpenRateLabel}</div>
                <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:600;font-size:1.5rem;margin-top:4px;color:var(--primary);">{t.hero.statOpenRateValue}</div>
              </div>
              <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:11px;padding:13px;">
                <div style="font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;">{t.hero.statClickRateLabel}</div>
                <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:600;font-size:1.5rem;margin-top:4px;color:var(--amber);">{t.hero.statClickRateValue}</div>
              </div>
              <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:11px;padding:13px;">
                <div style="font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;">{t.hero.statBouncedLabel}</div>
                <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:600;font-size:1.5rem;margin-top:4px;">{t.hero.statBouncedValue}</div>
              </div>
            </div>
            <div style="margin-top:16px;">
              <div style="display:flex;align-items:center;justify-content:space-between;font-size:.74rem;color:var(--muted);margin-bottom:8px;"><span>{t.hero.chartLabel}</span><span style="font-family:'JetBrains Mono Variable',monospace;">{t.hero.chartCost}</span></div>
              <div style="display:flex;align-items:flex-end;gap:5px;height:64px;">
                <div style="flex:1;height:22%;background:var(--primary-weak);border-radius:4px 4px 0 0;"></div>
                <div style="flex:1;height:46%;background:var(--primary-weak);border-radius:4px 4px 0 0;"></div>
                <div style="flex:1;height:70%;background:var(--primary);border-radius:4px 4px 0 0;"></div>
                <div style="flex:1;height:100%;background:var(--primary);border-radius:4px 4px 0 0;"></div>
                <div style="flex:1;height:82%;background:var(--primary);border-radius:4px 4px 0 0;"></div>
                <div style="flex:1;height:55%;background:var(--primary-weak);border-radius:4px 4px 0 0;"></div>
                <div style="flex:1;height:38%;background:var(--primary-weak);border-radius:4px 4px 0 0;"></div>
                <div style="flex:1;height:28%;background:var(--primary-weak);border-radius:4px 4px 0 0;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== TRUST STRIP ===================== -->
    <section aria-label={t.trust.ariaLabel} style="border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--surface);">
      <div style="max-width:1180px;margin:0 auto;padding:22px 24px;display:flex;align-items:center;gap:clamp(16px,4vw,42px);flex-wrap:wrap;justify-content:center;">
        <span style="font-size:.8rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;font-weight:600;">{t.trust.label}</span>
        <span style="font-family:'JetBrains Mono Variable',monospace;font-weight:600;color:var(--fg);opacity:.85;">{t.trust.go}</span>
        <span style="font-family:'JetBrains Mono Variable',monospace;font-weight:600;color:var(--fg);opacity:.85;">{t.trust.postgres}</span>
        <span style="font-family:'JetBrains Mono Variable',monospace;font-weight:600;color:var(--fg);opacity:.85;">{t.trust.react}</span>
        <span style="font-family:'JetBrains Mono Variable',monospace;font-weight:600;color:var(--fg);opacity:.85;">{t.trust.ses}</span>
        <span style="font-family:'JetBrains Mono Variable',monospace;font-weight:600;color:var(--fg);opacity:.85;">{t.trust.stack}</span>
      </div>
    </section>

    <!-- ===================== WHY PLUME ===================== -->
    <section id="why" style="max-width:1180px;margin:0 auto;padding:clamp(56px,9vw,104px) 24px;">
      <div style="max-width:640px;">
