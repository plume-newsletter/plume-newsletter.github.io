            </div>
            <div style="border:1px solid var(--primary);border-radius:12px;padding:16px;background:var(--primary-weak);">
              <div style="font-size:.78rem;color:var(--primary);font-weight:700;">{t.pricing.plumeSesLabel}</div>
              <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:700;font-size:1.7rem;margin-top:6px;color:var(--primary);"><span id="v-plume">{t.pricing.plumeSesValue}</span></div>
              <div style="font-size:.74rem;color:var(--primary);margin-top:2px;">{t.pricing.plumeSesUnit}</div>
            </div>
