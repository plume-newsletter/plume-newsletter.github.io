<script define:vars={{ copyLabel: t.quickstart.copyLabel, copiedLabel: t.quickstart.copiedLabel }}>
  const html = document.documentElement;

  // theme toggle
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  // ponytail: reproduces the prototype's style-hover / style-focus runtime so the
  // markup ports verbatim. Swap to CSS classes if this page grows much.
  document.querySelectorAll('[style-hover],[style-focus]').forEach((el) => {
    const base = el.getAttribute('style') || '';
    const h = el.getAttribute('style-hover') || '';
    const f = el.getAttribute('style-focus') || '';
    let hovering = false, focusing = false;
    const apply = () => el.setAttribute('style', base + (hovering && h ? ';' + h : '') + (focusing && f ? ';' + f : ''));
    if (h) { el.addEventListener('mouseenter', () => { hovering = true; apply(); });
             el.addEventListener('mouseleave', () => { hovering = false; apply(); }); }
    if (f) { el.addEventListener('focus', () => { focusing = true; apply(); });
             el.addEventListener('blur',  () => { focusing = false; apply(); }); }
  });

  // pricing calculator
  const fmt = (n) => Math.round(n).toLocaleString('en-US');
  const money = (n) => '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const saasMonthly = (subs) => {
    const tiers = [[1000,30],[2500,50],[5000,75],[10000,110],[25000,230],[50000,385],[75000,575],[100000,800]];
    for (const [cap, price] of tiers) if (subs <= cap) return price;
    return 800 + ((subs - 100000) / 1000) * 6;
  };
  const set = (id, t) => { const e = document.getElementById(id); if (e) e.textContent = t; };
  const slider = document.getElementById('listsize');
  const calc = () => {
    const subs = +slider.value, emails = subs * 4, ses = (emails / 1000) * 0.10, saas = saasMonthly(subs);
    set('v-list', fmt(subs)); set('v-emails', fmt(emails)); set('v-saas', '$' + fmt(saas));
    set('v-plume', money(ses)); set('v-save', Math.max(0, Math.round((1 - ses / saas) * 100)) + '%');
  };
  if (slider) { slider.addEventListener('input', calc); calc(); }

  // copy quickstart command
  document.getElementById('copy-cmd')?.addEventListener('click', () => {
    navigator.clipboard?.writeText('docker compose up -d');
    const l = document.getElementById('copy-label');
    if (l) { l.textContent = copiedLabel; setTimeout(() => (l.textContent = copyLabel), 1800); }
  });


  // live GitHub star count (per-visitor IP quota; static fallback already rendered)
  fetch('https://api.github.com/repos/plume-newsletter/plume')
    .then((r) => r.json())
    .then((d) => {
      const n = d && d.stargazers_count;
      if (typeof n !== 'number') return;
      set('gh-stars', n >= 1000 ? (n / 1000).toFixed(1).replace(/\.0$/, '') + 'k' : String(n));
    })
    .catch(() => {});
</script>
<script define:vars={{ wl: t.waitlist.js }}>
  (() => {
    const form = document.getElementById('wait-form');
    if (!form) return;
    const email = document.getElementById('wait-email');
    const openEl = document.getElementById('wait-open');
    const doneEl = document.getElementById('wait-done');
    const errWrap = document.getElementById('wait-error-wrap');
    const errMsg = document.getElementById('wait-error-msg');
    const btn = form.querySelector('button[type="submit"]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const value = (email.value || '').trim();
      if (!value) return;
      errWrap.style.display = 'none';
      const label = btn.textContent;
      btn.disabled = true;
      btn.textContent = wl.sending;
      try {
        const res = await fetch('https://app.plumenewsletter.com/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: value }),
        });
        if (res.ok) {
          openEl.style.display = 'none';
          doneEl.style.display = 'block';
          return;
        }
        errMsg.textContent = res.status === 429
          ? wl.tooMany
          : wl.genericError;
      } catch (_) {
        errMsg.textContent = wl.networkError;
      }
      errWrap.style.display = 'block';
      btn.disabled = false;
      btn.textContent = label;
    });
  })();
</script>
</body>
