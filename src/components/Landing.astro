            <span>{t.pricing.scaleMin}</span><span><span id="v-emails">{t.pricing.scaleEmailsValue}</span> {t.pricing.scaleEmailsSuffix}</span><span>{t.pricing.scaleMax}</span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:22px;">
            <div style="border:1px solid var(--border);border-radius:12px;padding:16px;background:var(--surface);">
              <div style="font-size:.78rem;color:var(--muted);font-weight:600;">{t.pricing.typicalSaasLabel}</div>
              <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:700;font-size:1.7rem;margin-top:6px;text-decoration:line-through;text-decoration-color:var(--muted);opacity:.8;"><span id="v-saas">{t.pricing.typicalSaasValue}</span></div>
