---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import type { CompareStrings } from '../i18n/compare';
const { locale, t } = Astro.props as { locale: 'en' | 'th'; t: CompareStrings };
const site = Astro.site ?? new URL('https://plume-newsletter.github.io');
const docsBase = locale === 'th' ? '/th/docs' : '/docs';
const homeHref = locale === 'th' ? '/th/' : '/';
const hreflangEn = new URL('compare/', site).href;
const hreflangTh = new URL('th/compare/', site).href;
const canonical = locale === 'th' ? hreflangTh : hreflangEn;
const rows = t.matrix.rows;
---
<!doctype html>
<html lang={locale}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{t.meta.title}</title>
  <meta name="description" content={t.meta.description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en" href={hreflangEn} />
  <link rel="alternate" hreflang="th" href={hreflangTh} />
  <link rel="alternate" hreflang="x-default" href={hreflangEn} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={t.meta.title} />
  <meta property="og:description" content={t.meta.ogDescription} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={t.meta.title} />
  <meta name="twitter:description" content={t.meta.twitterDescription} />
  <meta property="og:image" content="https://plumenewsletter.com/og.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:image" content="https://plumenewsletter.com/og.png" />
  <style is:global>
    *{box-sizing:border-box;}
    body{margin:0;}
    html,body{background:var(--bg);}
    :root{
      --bg:oklch(0.984 0.003 247.858);--surface:#fff;--surface-2:oklch(0.972 0.006 256.695);
      --fg:oklch(0.208 0.040 265.755);--muted:oklch(0.554 0.041 257.417);--faint:oklch(0.704 0.035 257);
      --border:oklch(0.913 0.017 256.284);--border-strong:oklch(0.865 0.020 256);
      --primary:oklch(0.623 0.188 260);--primary-weak:oklch(0.949 0.030 260);--primary-text:oklch(0.470 0.188 260);
      --amber:oklch(0.555 0.146 48.998);--amber-weak:oklch(0.952 0.040 70);
      --success:oklch(0.520 0.150 162.48);--success-weak:oklch(0.950 0.045 162);
      --danger:oklch(0.577 0.215 27.325);
      --shadow-sm:0 1px 2px rgba(15,23,42,.05);--shadow:0 1px 2px rgba(15,23,42,.06),0 12px 28px -14px rgba(15,23,42,.18);
    }
    [data-theme="dark"]{
      --bg:oklch(0.183 0.031 263.383);--surface:oklch(0.210 0.032 264.665);--surface-2:oklch(0.245 0.034 262);
      --fg:oklch(0.929 0.013 255.508);--muted:oklch(0.711 0.035 256.788);--faint:oklch(0.580 0.035 257);
      --border:oklch(0.278 0.030 256.848);--border-strong:oklch(0.345 0.032 258);
      --primary:oklch(0.623 0.188 259.815);--primary-weak:oklch(0.300 0.062 262);--primary-text:oklch(0.720 0.150 262);
      --amber:oklch(0.705 0.142 55);--amber-weak:oklch(0.320 0.070 60);
      --success:oklch(0.627 0.194 145.57);--success-weak:oklch(0.300 0.070 150);
      --danger:oklch(0.640 0.200 25);
      --shadow-sm:0 1px 2px rgba(0,0,0,.4);--shadow:0 1px 2px rgba(0,0,0,.4),0 14px 32px -16px rgba(0,0,0,.6);
    }
    html[data-theme="dark"] .theme-ico-light{display:none;}
    html:not([data-theme="dark"]) .theme-ico-dark{display:none;}
    .theme-ico{display:inline-flex;}
  </style>
  <script is:inline>
    (function () {
      var t = localStorage.getItem('theme');
      if (t !== 'light' && t !== 'dark') {
        t = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
<div style="background:var(--bg);color:var(--fg);font-family:'Inter Variable',system-ui,sans-serif;min-height:100vh;-webkit-font-smoothing:antialiased;line-height:1.5;transition:background .3s;">

  <!-- NAV -->
  <header style="border-bottom:1px solid var(--border);background:var(--surface);position:sticky;top:0;z-index:30;">
    <div style="max-width:1100px;margin:0 auto;padding:14px 24px;display:flex;align-items:center;gap:14px;">
      <a href={homeHref} style="display:flex;align-items:center;gap:14px;text-decoration:none;color:var(--fg);">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:9px;background:var(--primary);"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><path d="M17.5 15H9"/></svg></span>
        <span style="font-weight:700;font-size:1.12rem;letter-spacing:-.01em;">{t.nav.brand}</span>
        <span style="color:var(--faint);font-size:.95rem;">{t.nav.breadcrumb}</span>
      </a>
      <div style="margin-left:auto;display:flex;align-items:center;gap:10px;">
        <a href={locale === 'th' ? '/compare/' : '/th/compare/'} lang={locale === 'th' ? 'en' : 'th'}
           style="display:inline-flex;align-items:center;gap:7px;text-decoration:none;color:var(--fg);font-size:.88rem;font-weight:600;height:36px;padding:0 12px;border-radius:9px;border:1px solid var(--border);background:var(--bg);"
           style-hover="background:var(--surface-2);border-color:var(--border-strong);"
           style-focus="outline:2px solid var(--primary);outline-offset:2px;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          {locale === 'th' ? t.nav.toggleToEn : t.nav.toggleToTh}</a>
        <button id="theme-toggle" aria-label={t.nav.themeToggleAria} style="width:36px;height:36px;border-radius:9px;border:1px solid var(--border);background:var(--bg);color:var(--fg);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;" style-hover="background:var(--surface-2);">
          <div class="theme-ico theme-ico-dark"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg></div>
          <div class="theme-ico theme-ico-light"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13.5A8 8 0 1 1 10.5 4a6.2 6.2 0 0 0 9.5 9.5Z"/></svg></div>
        </button>
        <a href="https://github.com/plume-newsletter/plume" style="display:inline-flex;align-items:center;text-decoration:none;color:#fff;font-size:.88rem;font-weight:600;padding:9px 15px;border-radius:9px;background:var(--amber);" style-hover="filter:brightness(.94);">{t.nav.getStarted}</a>
      </div>
    </div>
  </header>

  <main style="max-width:1100px;margin:0 auto;padding:clamp(40px,6vw,72px) 24px 80px;">
    <!-- HERO -->
    <div style="max-width:720px;">
      <span style="font-size:.82rem;font-weight:600;color:var(--amber);text-transform:uppercase;letter-spacing:.07em;">{t.hero.eyebrow}</span>
      <h1 style="font-size:clamp(2rem,4.5vw,3rem);font-weight:800;letter-spacing:-.025em;line-height:1.08;margin:12px 0 0;text-wrap:balance;">{t.hero.heading}</h1>
      <p style="font-size:1.12rem;color:var(--muted);margin:16px 0 0;text-wrap:pretty;">{t.hero.body}</p>
    </div>

    <!-- COST CALCULATOR -->
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:18px;box-shadow:var(--shadow);padding:clamp(22px,3vw,32px);margin-top:40px;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-bottom:24px;">
        <div><h2 style="font-size:1.3rem;font-weight:700;margin:0;">{t.calculator.heading}</h2><p style="color:var(--muted);font-size:.9rem;margin:5px 0 0;">{t.calculator.body}</p></div>
        <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:700;font-size:1.5rem;color:var(--primary-text);"><span id="v-list">25,000</span> {t.calculator.listSuffix}</div>
      </div>
      <input id="listsize" type="range" min="1000" max="100000" step="1000" value="25000" aria-label={t.calculator.sliderAria} style="width:100%;accent-color:var(--amber);cursor:pointer;height:6px;margin-bottom:24px;" />
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px;">
        <div style="border:1.5px solid var(--primary);border-radius:14px;padding:18px;background:var(--primary-weak);position:relative;">
          <span style="position:absolute;top:14px;right:14px;font-size:.64rem;font-weight:700;color:#fff;background:var(--primary);border-radius:5px;padding:2px 7px;">{t.calculator.youBadge}</span>
          <div style="font-size:.82rem;font-weight:700;color:var(--primary-text);">{t.calculator.plumeLabel}</div>
          <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:700;font-size:2rem;color:var(--primary-text);margin-top:6px;"><span id="v-plume">{t.calculator.plumeValue}</span></div>
          <div style="font-size:.74rem;color:var(--primary-text);margin-top:2px;">{t.calculator.plumeUnit}</div>
        </div>
        <div style="border:1px solid var(--border);border-radius:14px;padding:18px;background:var(--bg);">
          <div style="font-size:.82rem;font-weight:600;color:var(--muted);">{t.calculator.mailchimpLabel}</div>
          <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:700;font-size:2rem;margin-top:6px;"><span id="v-mc">{t.calculator.mailchimpValue}</span></div>
          <div style="font-size:.74rem;color:var(--success);margin-top:2px;font-weight:600;">{t.calculator.morePrefix}<span id="v-mcsave">23×</span>{t.calculator.moreSuffix}</div>
        </div>
        <div style="border:1px solid var(--border);border-radius:14px;padding:18px;background:var(--bg);">
          <div style="font-size:.82rem;font-weight:600;color:var(--muted);">{t.calculator.convertkitLabel}</div>
          <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:700;font-size:2rem;margin-top:6px;"><span id="v-ck">{t.calculator.convertkitValue}</span></div>
          <div style="font-size:.74rem;color:var(--success);margin-top:2px;font-weight:600;">{t.calculator.morePrefix}<span id="v-cksave">22×</span>{t.calculator.moreSuffix}</div>
        </div>
      </div>
      <p style="font-size:.78rem;color:var(--faint);margin:18px 0 0;font-style:italic;">{t.calculator.footnote1}</p>
      <p style="font-size:.78rem;color:var(--faint);margin:6px 0 0;font-style:italic;">{t.calculator.footnote2}</p>
    </div>

    <!-- FEATURE MATRIX -->
    <h2 style="font-size:1.5rem;font-weight:800;letter-spacing:-.01em;margin:56px 0 4px;">{t.matrix.heading}</h2>
    <p style="color:var(--muted);margin:0 0 24px;">{t.matrix.body}</p>
    <div style="border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:var(--shadow-sm);background:var(--surface);">
      <div style="display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:0;background:var(--surface-2);border-bottom:1px solid var(--border);font-size:.74rem;text-transform:uppercase;letter-spacing:.04em;font-weight:700;color:var(--faint);">
        <div style="padding:14px 18px;"></div>
        <div style="padding:14px 14px;text-align:center;color:var(--primary-text);display:flex;align-items:center;justify-content:center;gap:6px;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><path d="M17.5 15H9"/></svg>{t.matrix.colPlume}</div>
        <div style="padding:14px 14px;text-align:center;">{t.matrix.colMailchimp}</div>
        <div style="padding:14px 14px;text-align:center;">{t.matrix.colConvertKit}</div>
      </div>
      {rows.map((r) => (
        <div style="display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:0;border-bottom:1px solid var(--border);align-items:center;">
          <div style="padding:14px 18px;font-weight:600;font-size:.92rem;">{r.label}</div>
          <div style="padding:14px 14px;text-align:center;background:var(--primary-weak);">{r.plume}</div>
          <div style="padding:14px 14px;text-align:center;color:var(--muted);font-size:.88rem;">{r.mc}</div>
          <div style="padding:14px 14px;text-align:center;color:var(--muted);font-size:.88rem;">{r.ck}</div>
        </div>
      ))}
    </div>

    <!-- HONEST TRADE-OFFS -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-top:32px;">
      <div style="border:1px solid var(--border);border-radius:14px;padding:20px;background:var(--surface);">
        <div style="font-weight:700;display:flex;align-items:center;gap:8px;margin-bottom:8px;"><span style="color:var(--success);">✓</span>{t.tradeoffs.winHeading}</div>
        <ul style="margin:0;padding-left:20px;color:var(--muted);font-size:.9rem;">{t.tradeoffs.winItems.map((item) => <li style="margin-bottom:5px;">{item}</li>)}</ul>
      </div>
      <div style="border:1px solid var(--border);border-radius:14px;padding:20px;background:var(--surface);">
        <div style="font-weight:700;display:flex;align-items:center;gap:8px;margin-bottom:8px;"><span style="color:var(--amber);">!</span>{t.tradeoffs.honestHeading}</div>
        <ul style="margin:0;padding-left:20px;color:var(--muted);font-size:.9rem;">{t.tradeoffs.honestItems.map((item) => <li style="margin-bottom:5px;">{item}</li>)}</ul>
      </div>
    </div>

    <!-- CTA -->
    <div style="background:var(--primary);border-radius:18px;padding:clamp(28px,4vw,44px);text-align:center;margin-top:48px;">
      <h2 style="color:#fff;font-size:clamp(1.5rem,3vw,2rem);font-weight:800;letter-spacing:-.02em;margin:0;text-wrap:balance;">{t.cta.heading}</h2>
      <p style="color:rgba(255,255,255,.85);margin:12px auto 0;max-width:46ch;">{t.cta.body}</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:24px;">
        <a href={`${docsBase}/quickstart/`} style="display:inline-flex;align-items:center;text-decoration:none;color:#fff;font-weight:600;padding:12px 22px;border-radius:10px;background:var(--amber);" style-hover="filter:brightness(.94);">{t.cta.ctaPrimary}</a>
        <a href="https://github.com/plume-newsletter/plume" style="display:inline-flex;align-items:center;text-decoration:none;color:var(--primary);font-weight:600;padding:12px 22px;border-radius:10px;background:#fff;" style-hover="filter:brightness(.96);">{t.cta.ctaSecondary}</a>
      </div>
    </div>
  </main>
</div>

<script>
  const html = document.documentElement;
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  // ponytail: same style-hover/style-focus shim as the landing page
  document.querySelectorAll('[style-hover],[style-focus]').forEach((el) => {
    const base = el.getAttribute('style') || '';
    const h = el.getAttribute('style-hover') || '';
    const f = el.getAttribute('style-focus') || '';
    let hovering = false, focusing = false;
    const apply = () => el.setAttribute('style', base + (hovering && h ? ';' + h : '') + (focusing && f ? ';' + f : ''));
    if (h) { el.addEventListener('mouseenter', () => { hovering = true; apply(); });
             el.addEventListener('mouseleave', () => { hovering = false; apply(); }); }
    if (f) { el.addEventListener('focus', () => { focusing = true; apply(); });
             el.addEventListener('blur',  () => { focusing = false; apply(); }); }
  });

  // cost calculator — ported 1:1 from the prototype (published Standard-tier pricing)
  const fmt = (n) => n.toLocaleString('en-US');
  const money = (n) => '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const tier = (table, subs) => { for (const [cap, price] of table) if (subs <= cap) return price; return table[table.length - 1][1]; };
  const MC = [[500,13],[1500,26],[2500,45],[5000,75],[10000,110],[25000,230],[50000,385],[75000,575],[100000,800]];
  const CK = [[1000,29],[3000,49],[5000,79],[10000,119],[25000,219],[50000,379],[75000,549],[100000,729]];
  const mult = (saas, ses) => (saas / Math.max(ses, 0.01)) >= 10 ? Math.round(saas / Math.max(ses, 0.01)) + '×' : '$' + fmt(Math.round(saas - ses));
  const set = (id, t) => { const e = document.getElementById(id); if (e) e.textContent = t; };
  const slider = document.getElementById('listsize');
  const calc = () => {
    const subs = +slider.value, ses = (subs * 4 / 1000) * 0.10, mc = tier(MC, subs), ck = tier(CK, subs);
    set('v-list', fmt(subs)); set('v-plume', money(ses));
    set('v-mc', '$' + fmt(mc)); set('v-ck', '$' + fmt(ck));
    set('v-mcsave', mult(mc, ses)); set('v-cksave', mult(ck, ses));
  };
  if (slider) { slider.addEventListener('input', calc); calc(); }
</script>
</body>
</html>
