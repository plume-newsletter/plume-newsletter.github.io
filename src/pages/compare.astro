---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
const canonical = new URL('/compare/', Astro.site ?? 'https://plume-newsletter.github.io').href;
const rows = [
  { label: 'Pricing model', plume: 'AWS cost', mc: 'Per subscriber', ck: 'Per subscriber' },
  { label: 'Self-hosted / own data', plume: '✓', mc: '—', ck: '—' },
  { label: 'Open source', plume: 'AGPL-3.0', mc: '—', ck: '—' },
  { label: 'Drag-and-drop builder', plume: '✓', mc: '✓', ck: 'Basic' },
  { label: 'Automations', plume: '✓', mc: '✓', ck: '✓' },
  { label: 'A/B testing', plume: '✓', mc: 'Paid tiers', ck: 'Paid tiers' },
  { label: 'Hooks / extensibility', plume: 'First-class', mc: 'API only', ck: 'API only' },
  { label: 'Email providers', plume: 'SES, Mailgun, SendGrid, Postmark, Resend, any SMTP', mc: 'Built-in sender only', ck: 'Built-in sender only' },
  { label: 'Vendor lock-in', plume: 'None', mc: 'High', ck: 'High' },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Plume vs Mailchimp vs ConvertKit — newsletter cost compared</title>
  <meta name="description" content="See how Plume's self-hosted, send-through-your-own-email-provider model compares to Mailchimp and ConvertKit on price, data ownership, and features as your list grows." />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Plume vs Mailchimp vs ConvertKit — newsletter cost compared" />
  <meta property="og:description" content="The same emails, without the per-subscriber bill. A cost + feature comparison of Plume against hosted newsletter SaaS." />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Plume vs Mailchimp vs ConvertKit — newsletter cost compared" />
  <meta name="twitter:description" content="The same emails, without the per-subscriber bill." />
  <meta property="og:image" content="https://plumenewsletter.com/og.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:image" content="https://plumenewsletter.com/og.png" />
  <style is:global>
    *{box-sizing:border-box;}
    body{margin:0;}
    html,body{background:var(--bg);}
    :root{
      --bg:oklch(0.984 0.003 247.858);--surface:#fff;--surface-2:oklch(0.972 0.006 256.695);
      --fg:oklch(0.208 0.040 265.755);--muted:oklch(0.554 0.041 257.417);--faint:oklch(0.704 0.035 257);
      --border:oklch(0.913 0.017 256.284);--border-strong:oklch(0.865 0.020 256);
      --primary:oklch(0.424 0.181 265.638);--primary-weak:oklch(0.949 0.030 264);--primary-text:oklch(0.470 0.181 265.638);
      --amber:oklch(0.555 0.146 48.998);--amber-weak:oklch(0.952 0.040 70);
      --success:oklch(0.520 0.150 162.48);--success-weak:oklch(0.950 0.045 162);
      --danger:oklch(0.577 0.215 27.325);
      --shadow-sm:0 1px 2px rgba(15,23,42,.05);--shadow:0 1px 2px rgba(15,23,42,.06),0 12px 28px -14px rgba(15,23,42,.18);
    }
    [data-theme="dark"]{
      --bg:oklch(0.183 0.031 263.383);--surface:oklch(0.210 0.032 264.665);--surface-2:oklch(0.245 0.034 262);
      --fg:oklch(0.929 0.013 255.508);--muted:oklch(0.711 0.035 256.788);--faint:oklch(0.580 0.035 257);
      --border:oklch(0.278 0.030 256.848);--border-strong:oklch(0.345 0.032 258);
      --primary:oklch(0.623 0.188 259.815);--primary-weak:oklch(0.300 0.062 262);--primary-text:oklch(0.720 0.150 262);
      --amber:oklch(0.705 0.142 55);--amber-weak:oklch(0.320 0.070 60);
      --success:oklch(0.627 0.194 145.57);--success-weak:oklch(0.300 0.070 150);
      --danger:oklch(0.640 0.200 25);
      --shadow-sm:0 1px 2px rgba(0,0,0,.4);--shadow:0 1px 2px rgba(0,0,0,.4),0 14px 32px -16px rgba(0,0,0,.6);
    }
    html[data-theme="dark"] .theme-ico-light{display:none;}
    html:not([data-theme="dark"]) .theme-ico-dark{display:none;}
    .theme-ico{display:inline-flex;}
  </style>
  <script is:inline>
    (function () {
      var t = localStorage.getItem('theme');
      if (t !== 'light' && t !== 'dark') {
        t = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
<div style="background:var(--bg);color:var(--fg);font-family:'Inter Variable',system-ui,sans-serif;min-height:100vh;-webkit-font-smoothing:antialiased;line-height:1.5;transition:background .3s;">

  <!-- NAV -->
  <header style="border-bottom:1px solid var(--border);background:var(--surface);position:sticky;top:0;z-index:30;">
    <div style="max-width:1100px;margin:0 auto;padding:14px 24px;display:flex;align-items:center;gap:14px;">
      <a href="/" style="display:flex;align-items:center;gap:14px;text-decoration:none;color:var(--fg);">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:9px;background:var(--primary);"><svg width="18" height="18" viewBox="0 0 100 100" aria-hidden="true"><g transform="rotate(-34 50 50)"><path fill="#fff" fill-rule="evenodd" d="M50 6 C70 22 80 46 71 66 C66 78 58 88 50 96 C42 88 34 78 29 66 C20 46 30 22 50 6 Z M50 24 C52 42 52 64 51 86 C50 90 50 90 49 86 C48 64 48 42 50 24 Z"/></g></svg></span>
        <span style="font-weight:700;font-size:1.12rem;letter-spacing:-.01em;">Plume</span>
        <span style="color:var(--faint);font-size:.95rem;">/ Compare</span>
      </a>
      <div style="margin-left:auto;display:flex;align-items:center;gap:10px;">
        <button id="theme-toggle" aria-label="Toggle theme" style="width:36px;height:36px;border-radius:9px;border:1px solid var(--border);background:var(--bg);color:var(--fg);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;" style-hover="background:var(--surface-2);">
          <div class="theme-ico theme-ico-dark"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg></div>
          <div class="theme-ico theme-ico-light"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13.5A8 8 0 1 1 10.5 4a6.2 6.2 0 0 0 9.5 9.5Z"/></svg></div>
        </button>
        <a href="https://github.com/plume-newsletter/plume" style="display:inline-flex;align-items:center;text-decoration:none;color:#fff;font-size:.88rem;font-weight:600;padding:9px 15px;border-radius:9px;background:var(--amber);" style-hover="filter:brightness(.94);">Get started</a>
      </div>
    </div>
  </header>

  <main style="max-width:1100px;margin:0 auto;padding:clamp(40px,6vw,72px) 24px 80px;">
    <!-- HERO -->
    <div style="max-width:720px;">
      <span style="font-size:.82rem;font-weight:600;color:var(--amber);text-transform:uppercase;letter-spacing:.07em;">Plume vs hosted SaaS</span>
      <h1 style="font-size:clamp(2rem,4.5vw,3rem);font-weight:800;letter-spacing:-.025em;line-height:1.08;margin:12px 0 0;text-wrap:balance;">The same emails, without the per-subscriber bill.</h1>
      <p style="font-size:1.12rem;color:var(--muted);margin:16px 0 0;text-wrap:pretty;">Mailchimp and ConvertKit charge by how many people are on your list. Plume charges nothing for the software and passes through Amazon SES at cost. Here's what that means as you grow.</p>
    </div>

    <!-- COST CALCULATOR -->
    <div style="background:var(--surface);border:1px solid var(--border);border-radius:18px;box-shadow:var(--shadow);padding:clamp(22px,3vw,32px);margin-top:40px;">
      <div style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;margin-bottom:24px;">
        <div><h2 style="font-size:1.3rem;font-weight:700;margin:0;">Monthly cost at your list size</h2><p style="color:var(--muted);font-size:.9rem;margin:5px 0 0;">Assuming 4 sends/month. Drag to your audience.</p></div>
        <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:700;font-size:1.5rem;color:var(--primary-text);"><span id="v-list">25,000</span> subs</div>
      </div>
      <input id="listsize" type="range" min="1000" max="100000" step="1000" value="25000" aria-label="List size" style="width:100%;accent-color:var(--amber);cursor:pointer;height:6px;margin-bottom:24px;" />
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px;">
        <div style="border:1.5px solid var(--primary);border-radius:14px;padding:18px;background:var(--primary-weak);position:relative;">
          <span style="position:absolute;top:14px;right:14px;font-size:.64rem;font-weight:700;color:#fff;background:var(--primary);border-radius:5px;padding:2px 7px;">YOU</span>
          <div style="font-size:.82rem;font-weight:700;color:var(--primary-text);">Plume + SES</div>
          <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:700;font-size:2rem;color:var(--primary-text);margin-top:6px;"><span id="v-plume">$10.00</span></div>
          <div style="font-size:.74rem;color:var(--primary-text);margin-top:2px;">per month, all-in sending</div>
        </div>
        <div style="border:1px solid var(--border);border-radius:14px;padding:18px;background:var(--bg);">
          <div style="font-size:.82rem;font-weight:600;color:var(--muted);">Mailchimp</div>
          <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:700;font-size:2rem;margin-top:6px;"><span id="v-mc">$230</span></div>
          <div style="font-size:.74rem;color:var(--success);margin-top:2px;font-weight:600;"><span id="v-mcsave">23×</span> more</div>
        </div>
        <div style="border:1px solid var(--border);border-radius:14px;padding:18px;background:var(--bg);">
          <div style="font-size:.82rem;font-weight:600;color:var(--muted);">ConvertKit</div>
          <div style="font-family:'JetBrains Mono Variable',monospace;font-weight:700;font-size:2rem;margin-top:6px;"><span id="v-ck">$219</span></div>
          <div style="font-size:.74rem;color:var(--success);margin-top:2px;font-weight:600;"><span id="v-cksave">22×</span> more</div>
        </div>
      </div>
      <p style="font-size:.78rem;color:var(--faint);margin:18px 0 0;font-style:italic;">Estimates from published Standard-tier pricing; SES at $0.10/1,000 emails. Add a small server (~$5–10/mo) to self-host Plume.</p>
      <p style="font-size:.78rem;color:var(--faint);margin:6px 0 0;font-style:italic;">Calculated with Amazon SES pricing — Plume works with any SMTP provider.</p>
    </div>

    <!-- FEATURE MATRIX -->
    <h2 style="font-size:1.5rem;font-weight:800;letter-spacing:-.01em;margin:56px 0 4px;">Feature by feature</h2>
    <p style="color:var(--muted);margin:0 0 24px;">Where an open, self-hosted model wins — and the honest trade-offs.</p>
    <div style="border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:var(--shadow-sm);background:var(--surface);">
      <div style="display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:0;background:var(--surface-2);border-bottom:1px solid var(--border);font-size:.74rem;text-transform:uppercase;letter-spacing:.04em;font-weight:700;color:var(--faint);">
        <div style="padding:14px 18px;"></div>
        <div style="padding:14px 14px;text-align:center;color:var(--primary-text);display:flex;align-items:center;justify-content:center;gap:6px;"><svg width="14" height="14" viewBox="0 0 100 100" aria-hidden="true"><g transform="rotate(-34 50 50)"><path fill="var(--primary)" fill-rule="evenodd" d="M50 6 C70 22 80 46 71 66 C66 78 58 88 50 96 C42 88 34 78 29 66 C20 46 30 22 50 6 Z M50 24 C52 42 52 64 51 86 C50 90 50 90 49 86 C48 64 48 42 50 24 Z"/></g></svg>Plume</div>
        <div style="padding:14px 14px;text-align:center;">Mailchimp</div>
        <div style="padding:14px 14px;text-align:center;">ConvertKit</div>
      </div>
      {rows.map((r) => (
        <div style="display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:0;border-bottom:1px solid var(--border);align-items:center;">
          <div style="padding:14px 18px;font-weight:600;font-size:.92rem;">{r.label}</div>
          <div style="padding:14px 14px;text-align:center;background:var(--primary-weak);">{r.plume}</div>
          <div style="padding:14px 14px;text-align:center;color:var(--muted);font-size:.88rem;">{r.mc}</div>
          <div style="padding:14px 14px;text-align:center;color:var(--muted);font-size:.88rem;">{r.ck}</div>
        </div>
      ))}
    </div>

    <!-- HONEST TRADE-OFFS -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-top:32px;">
      <div style="border:1px solid var(--border);border-radius:14px;padding:20px;background:var(--surface);">
        <div style="font-weight:700;display:flex;align-items:center;gap:8px;margin-bottom:8px;"><span style="color:var(--success);">✓</span>Where Plume wins</div>
        <ul style="margin:0;padding-left:20px;color:var(--muted);font-size:.9rem;"><li style="margin-bottom:5px;">Cost stays flat as your list grows</li><li style="margin-bottom:5px;">You own the data and the sending reputation</li><li style="margin-bottom:5px;">Open source, extensible via hooks, no lock-in</li></ul>
      </div>
      <div style="border:1px solid var(--border);border-radius:14px;padding:20px;background:var(--surface);">
        <div style="font-weight:700;display:flex;align-items:center;gap:8px;margin-bottom:8px;"><span style="color:var(--amber);">!</span>Honest trade-offs</div>
        <ul style="margin:0;padding-left:20px;color:var(--muted);font-size:.9rem;"><li style="margin-bottom:5px;">You run a server and configure an email provider</li><li style="margin-bottom:5px;">You warm up your own sending domain</li><li style="margin-bottom:5px;">No phone support — community + docs</li></ul>
      </div>
    </div>

    <!-- CTA -->
    <div style="background:var(--primary);border-radius:18px;padding:clamp(28px,4vw,44px);text-align:center;margin-top:48px;">
      <h2 style="color:#fff;font-size:clamp(1.5rem,3vw,2rem);font-weight:800;letter-spacing:-.02em;margin:0;text-wrap:balance;">Stop paying for subscribers you already own.</h2>
      <p style="color:rgba(255,255,255,.85);margin:12px auto 0;max-width:46ch;">Self-host Plume in minutes. Free and open source under AGPL-3.0.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:24px;">
        <a href="/docs/quickstart/" style="display:inline-flex;align-items:center;text-decoration:none;color:#fff;font-weight:600;padding:12px 22px;border-radius:10px;background:var(--amber);" style-hover="filter:brightness(.94);">Get started</a>
        <a href="https://github.com/plume-newsletter/plume" style="display:inline-flex;align-items:center;text-decoration:none;color:var(--primary);font-weight:600;padding:12px 22px;border-radius:10px;background:#fff;" style-hover="filter:brightness(.96);">View on GitHub</a>
      </div>
    </div>
  </main>
</div>

<script>
  const html = document.documentElement;
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  // ponytail: same style-hover/style-focus shim as the landing page
  document.querySelectorAll('[style-hover],[style-focus]').forEach((el) => {
    const base = el.getAttribute('style') || '';
    const h = el.getAttribute('style-hover') || '';
    const f = el.getAttribute('style-focus') || '';
    let hovering = false, focusing = false;
    const apply = () => el.setAttribute('style', base + (hovering && h ? ';' + h : '') + (focusing && f ? ';' + f : ''));
    if (h) { el.addEventListener('mouseenter', () => { hovering = true; apply(); });
             el.addEventListener('mouseleave', () => { hovering = false; apply(); }); }
    if (f) { el.addEventListener('focus', () => { focusing = true; apply(); });
             el.addEventListener('blur',  () => { focusing = false; apply(); }); }
  });

  // cost calculator — ported 1:1 from the prototype (published Standard-tier pricing)
  const fmt = (n) => n.toLocaleString('en-US');
  const money = (n) => '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const tier = (table, subs) => { for (const [cap, price] of table) if (subs <= cap) return price; return table[table.length - 1][1]; };
  const MC = [[500,13],[1500,26],[2500,45],[5000,75],[10000,110],[25000,230],[50000,385],[75000,575],[100000,800]];
  const CK = [[1000,29],[3000,49],[5000,79],[10000,119],[25000,219],[50000,379],[75000,549],[100000,729]];
  const mult = (saas, ses) => (saas / Math.max(ses, 0.01)) >= 10 ? Math.round(saas / Math.max(ses, 0.01)) + '×' : '$' + fmt(Math.round(saas - ses));
  const set = (id, t) => { const e = document.getElementById(id); if (e) e.textContent = t; };
  const slider = document.getElementById('listsize');
  const calc = () => {
    const subs = +slider.value, ses = (subs * 4 / 1000) * 0.10, mc = tier(MC, subs), ck = tier(CK, subs);
    set('v-list', fmt(subs)); set('v-plume', money(ses));
    set('v-mc', '$' + fmt(mc)); set('v-ck', '$' + fmt(ck));
    set('v-mcsave', mult(mc, ses)); set('v-cksave', mult(ck, ses));
  };
  if (slider) { slider.addEventListener('input', calc); calc(); }
</script>
</body>
</html>
